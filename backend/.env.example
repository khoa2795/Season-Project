NODE_ENV=development
PORT=3001
MONGO_URI=mongodb://127.0.0.1:27017/season?replicaSet=rs0
MONGO_DB=season
ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=false
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
PASSWORD_RESET_URL=http://localhost:3000/reset-password
# Production should send reset payloads to a mail/queue webhook.
PASSWORD_RESET_DELIVERY_WEBHOOK_URL=
PASSWORD_RESET_DELIVERY_BEARER_TOKEN=
CLOUDINARY_URL=
